.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.detail-card {
  background: #ffffff;
}

.cover-placeholder {
  width: 100%;
  height: 500rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8c5a);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-emoji {
  font-size: 200rpx;
}

.content {
  padding: 40rpx 30rpx;
}

.header-section {
  margin-bottom: 30rpx;
}

.recipe-name {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.author-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.author {
  font-size: 28rpx;
  color: #666;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff9f5;
  border: 2rpx solid #ffe0d0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.total-price-label {
  font-size: 28rpx;
  color: #666;
}

.total-price-value {
  font-size: 36rpx;
  color: #ff6b35;
  font-weight: bold;
}

.section {
  margin-bottom: 10rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.images-scroll {
  white-space: nowrap;
}

.dish-images-list {
  display: inline-flex;
  gap: 16rpx;
}

.dish-image-item {
  width: 280rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 30rpx 0;
}

.ingredients-list {
  background: #fff9f5;
  border-radius: 12rpx;
  padding: 20rpx;
}

.ingredient-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #ffe0d0;
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-left {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ingredient-info {
  flex: 1;
}

.ingredient-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.ingredient-specs {
  font-size: 24rpx;
  color: #999;
}

.ingredient-price {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 500;
  margin-left: 20rpx;
}

.ingredient-image {
  margin-left: 16rpx;
}

.ingredient-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
}

.ingredients-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #ff6b35, #ff8c5a);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.total-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.total-value {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

.steps-list {
  background: #f5f9ff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.step-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e5f0ff;
}

.step-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.step-item:first-child {
  padding-top: 0;
}

.step-main {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.step-number {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8c5a);
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-text {
  flex: 1;
}

.step-text text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.step-image {
  margin-top: 16rpx;
  margin-left: 56rpx;
}

.step-thumb {
  width: 200rpx;
  height: 150rpx;
  border-radius: 10rpx;
}

.like-section {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 50rpx;
  padding-bottom: 30rpx;
}

.action-section {
  display: flex;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
  text-align: center;
  border: none;
}

.action-btn::after {
  border: none;
}

.edit-btn {
  background: #f0f5ff;
  color: #3b82f6;
}

.delete-btn {
  background: #fff0f0;
  color: #e64340;
}

.like-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background: #fff5f5;
  border: 2rpx solid #ffe0d0;
  border-radius: 44rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  line-height: 1;
}

.like-btn.liked {
  background: #fff0f0;
  border-color: #ff6b35;
}

.like-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  line-height: 1;
}

.like-count {
  color: #ff6b35;
  font-weight: bold;
  line-height: 1;
}

.loading {
  text-align: center;
  padding: 120rpx;
  color: #999;
  font-size: 28rpx;
}