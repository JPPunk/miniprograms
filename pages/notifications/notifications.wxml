<view class="container">
  <view class="notification-list" wx:if="{{notifications.length > 0}}">
    <view class="notification-item {{item.read ? 'read' : ''}}"
          wx:for="{{notifications}}"
          wx:key="id"
          bindtap="onNotificationTap"
          data-id="{{item.id}}">
      <view class="notification-icon">
        <text wx:if="{{item.type === 'like'}}">❤️</text>
      </view>
      <view class="notification-content">
        <text class="notification-text">{{item.message}}</text>
        <text class="notification-recipe">{{item.recipeName}}</text>
        <text class="notification-time">{{item.time}}</text>
      </view>
      <view class="unread-dot" wx:if="{{!item.read}}"></view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{notifications.length === 0}}">
    <text class="empty-icon">🔔</text>
    <text class="empty-text">暂无通知</text>
    <text class="empty-hint">收到点赞后会在这里显示</text>
  </view>
</view>