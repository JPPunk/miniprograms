<view class="container">
  <view class="header">
    <text class="title">🏆 排行榜</text>
    <text class="subtitle">划算小厨 · 每周更新</text>
  </view>

  <view class="tabs-bar">
    <view
      class="tab-item {{currentTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      bindtap="onTabChange"
      data-tab="{{item.key}}"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-name">{{item.name}}</text>
    </view>
  </view>

  <view class="content-area">
    <loading-state wx:if="{{loading}}" />

    <block wx:else>
      <view class="ranking-section" wx:for="{{rankingSections}}" wx:key="key" wx:if="{{currentTab === item.key}}">
        <view class="section-title">
          <text class="title-icon">{{item.icon}}</text>
          <text class="title-text">{{item.title}}</text>
          <text class="title-hint">{{item.hint}}</text>
        </view>

        <empty-state
          wx:if="{{item.list.length === 0}}"
          icon="🍽️"
          title="暂无菜谱"
          hint="上传第一个菜谱，开启排行榜吧"
        />

        <view class="recipe-list" wx:else>
          <recipe-card
            wx:for="{{getDisplayList(item.list, item.expanded)}}"
            wx:key="_id"
            recipe="{{item}}"
            showRank="{{true}}"
            rank="{{index}}"
            bindtap="goToDetail"
          >
            <view slot="meta" class="recipe-meta">
              <text class="meta-item" wx:for="{{getMetaList(item, currentTab)}}" wx:key="*this">{{item}}</text>
            </view>
          </recipe-card>
        </view>

        <view class="expand-btn" wx:if="{{item.list.length > previewCount}}">
          <view bindtap="toggleExpand" data-key="{{item.key}}" wx:if="{{!item.expanded}}">
            <text>查看全部 {{item.list.length}} 个菜谱</text>
            <text class="arrow">▼</text>
          </view>
          <view bindtap="toggleExpand" data-key="{{item.key}}" wx:if="{{item.expanded}}">
            <text>收起</text>
            <text class="arrow">▲</text>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
