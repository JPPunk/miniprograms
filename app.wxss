/* 设计令牌 / CSS 变量系统 */
page {
  /* 品牌色 */
  --primary: #ff6b35;
  --primary-light: #fff5f0;
  --primary-lighter: #ffd4c4;
  --primary-dark: #e55a2b;
  --gradient-primary: linear-gradient(135deg, #ff6b35, #ff8c5a);

  /* 背景色 */
  --bg-page: #f5f5f5;
  --bg-card: #ffffff;
  --bg-muted: #fafafa;
  --bg-pressed: #f0f0f0;

  /* 文字色 */
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --text-disabled: #cccccc;
  --text-inverse: #ffffff;

  /* 边框与分割 */
  --border-light: #eeeeee;
  --border-default: #e5e5e5;
  --divider: #f0f0f0;

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 20rpx;
  --radius-pill: 44rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 40rpx;

  /* 字体 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-md: 30rpx;
  --font-lg: 34rpx;
  --font-xl: 44rpx;

  /* 阴影 */
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-button: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);

  background-color: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: var(--text-primary);
}

/* 布局工具类 */
.container {
  padding: var(--space-sm);
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  margin-bottom: var(--space-sm);
  box-shadow: var(--shadow-card);
}

/* 按钮基础样式 */
.btn-primary {
  background: var(--gradient-primary);
  color: var(--text-inverse);
  border: none;
  border-radius: var(--radius-pill);
  padding: var(--space-sm) var(--space-md);
  font-size: var(--font-base);
  box-shadow: var(--shadow-button);
}

.btn-primary::after {
  border: none;
}

/* 表单基础样式 */
.input-group {
  margin-bottom: var(--space-md);
}

.input-label {
  font-size: var(--font-base);
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
  display: block;
  font-weight: 500;
}

.input-field {
  border: 2rpx solid var(--border-default);
  border-radius: var(--radius-md);
  padding: var(--space-sm);
  font-size: var(--font-base);
  background: var(--bg-muted);
}

.textarea-field {
  border: 2rpx solid var(--border-default);
  border-radius: var(--radius-md);
  padding: var(--space-sm);
  font-size: var(--font-base);
  background: var(--bg-muted);
  min-height: 200rpx;
}
